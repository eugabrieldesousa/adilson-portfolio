{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "titulo": {
      "type": "string"
    },
    "organizacao": {
      "type": "string"
    },
    "periodo": {
      "type": "string"
    },
    "localizacao": {
      "type": "string"
    },
    "resumo": {
      "type": "string"
    },
    "destaques": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "competencias": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ordem": {
      "default": 0,
      "type": "number"
    },
    "rascunho": {
      "default": true,
      "type": "boolean"
    },
    "tema": {
      "default": "azul",
      "type": "string",
      "enum": [
        "azul",
        "claro",
        "preto",
        "grafite"
      ]
    },
    "temaModal": {
      "type": "string",
      "enum": [
        "azul",
        "claro",
        "preto",
        "grafite"
      ]
    },
    "imagemCard": {
      "type": "string"
    },
    "imagemCardAlt": {
      "type": "string"
    },
    "alturaImagemCard": {
      "type": "integer",
      "minimum": 160,
      "maximum": 900
    },
    "tituloModal": {
      "type": "string"
    },
    "resumoModal": {
      "type": "string"
    },
    "midiaModal": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "tipo": {
              "type": "string",
              "const": "imagem"
            },
            "imagem": {
              "type": "string"
            },
            "alt": {
              "type": "string"
            }
          },
          "required": [
            "tipo",
            "imagem",
            "alt"
          ]
        },
        {
          "type": "object",
          "properties": {
            "tipo": {
              "type": "string",
              "const": "video"
            },
            "src": {
              "type": "string",
              "pattern": "^\\/.+\\.(mp4|webm)$"
            },
            "poster": {
              "type": "string"
            },
            "alt": {
              "type": "string"
            }
          },
          "required": [
            "tipo",
            "src",
            "poster",
            "alt"
          ]
        }
      ]
    },
    "url": {
      "anyOf": [
        {
          "type": "string",
          "format": "uri"
        },
        {
          "type": "string",
          "pattern": "^#[A-Za-z][\\w:.-]*$"
        }
      ]
    },
    "rotuloLink": {
      "type": "string"
    },
    "linksModal": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "rotulo": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "rotulo",
          "url"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "titulo",
    "imagemCard",
    "imagemCardAlt",
    "midiaModal"
  ]
}