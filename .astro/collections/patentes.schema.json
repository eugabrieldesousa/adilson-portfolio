{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "titulo": {
      "type": "string"
    },
    "numero": {
      "type": "string"
    },
    "jurisdicao": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "data": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "ordem": {
      "default": 0,
      "type": "number"
    },
    "rascunho": {
      "default": true,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "titulo"
  ]
}