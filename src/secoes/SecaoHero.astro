---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import { perfil } from '../dados/perfil';
import Botao from '../componentes/base/Botao.astro';
import Icone from '../componentes/base/Icone.astro';

const imagens = import.meta.glob<{ default: ImageMetadata }>('/src/assets/imagens/*.{jpg,jpeg,png,webp,avif}', {
  eager: true
});

const chaveRetrato = perfil.retratoArquivo ? `/src/assets/imagens/${perfil.retratoArquivo}` : '';
const retrato = chaveRetrato ? imagens[chaveRetrato]?.default : undefined;
---

<section id="home" class="hero" aria-labelledby="hero-title">
  <div class="hero__interno">
    <div class="hero__texto">
      <p class="hero__marcador">Professional Portfolio</p>
      <h1 id="hero-title">{perfil.nome}</h1>
      <p class="hero__titulo">{perfil.titulo}</p>
      <p class="hero__resumo">{perfil.resumoHero}</p>
      <div class="hero__acoes" aria-label="Primary actions">
        <Botao href="#contact" variante="primario">
          Contact
          <Icone nome="arrow-right" tamanho={17} />
        </Botao>
        <Botao href="#projects" variante="fantasma">View Work</Botao>
      </div>
    </div>

    <div class="hero__visual" aria-label="Professional portrait area">
      <div class="hero__retrato">
        {retrato ? (
          <Image
            src={retrato}
            alt={perfil.retratoAlt}
            loading="eager"
            decoding="async"
            widths={[320, 480, 640]}
            sizes="(min-width: 1024px) 360px, 78vw"
            class="hero__imagem"
          />
        ) : (
          <div class="hero__retrato-vazio" aria-hidden="true"></div>
        )}
      </div>
    </div>
  </div>

  <a class="hero__proxima" href="#about" aria-label="Continue to About">
    <span>About</span>
    <span class="hero__linha"></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    display: grid;
    min-height: 100dvh;
    align-items: center;
    padding: var(--espaco-16) var(--espaco-5) var(--espaco-20);
    overflow: hidden;
  }

  .hero__interno {
    display: grid;
    width: min(100%, var(--largura-conteudo));
    margin-inline: auto;
    gap: var(--espaco-10);
  }

  .hero__texto {
    min-width: 0;
    max-width: 640px;
  }

  .hero__marcador {
    margin: 0 0 var(--espaco-5);
    color: var(--cor-texto-minimo);
    font-size: 0.86rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-family: var(--fonte-display);
    font-size: 3.75rem;
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: 0;
    overflow-wrap: break-word;
  }

  .hero__titulo {
    margin: var(--espaco-5) 0 0;
    color: var(--cor-texto);
    font-size: 1.12rem;
    font-weight: 700;
    line-height: 1.35;
    overflow-wrap: break-word;
  }

  .hero__resumo {
    max-width: 48ch;
    margin: var(--espaco-4) 0 0;
    color: var(--cor-texto-suave);
    font-size: 1.05rem;
    overflow-wrap: break-word;
  }

  .hero__acoes {
    display: flex;
    flex-wrap: wrap;
    gap: var(--espaco-3);
    margin-top: var(--espaco-8);
  }

  .hero__visual {
    display: flex;
    justify-content: center;
  }

  .hero__retrato {
    position: relative;
    width: min(100%, 320px);
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border: 1px solid var(--cor-borda);
    border-radius: var(--raio-retrato);
    background: var(--cor-superficie-forte);
    box-shadow: var(--sombra-suave);
  }

  .hero__imagem {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__retrato-vazio {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(30deg, transparent 47%, var(--cor-borda-suave) 48%, var(--cor-borda-suave) 49%, transparent 50%),
      linear-gradient(150deg, transparent 47%, var(--cor-borda-suave) 48%, var(--cor-borda-suave) 49%, transparent 50%),
      var(--cor-superficie-forte);
    background-size: 96px 56px;
  }

  .hero__retrato-vazio::after {
    position: absolute;
    inset: var(--espaco-5);
    content: "";
    border: 1px solid var(--cor-borda);
    border-radius: 18px;
  }

  .hero__proxima {
    position: absolute;
    right: var(--espaco-5);
    bottom: var(--espaco-5);
    left: var(--espaco-5);
    display: flex;
    max-width: var(--largura-conteudo);
    align-items: center;
    gap: var(--espaco-3);
    margin-inline: auto;
    color: var(--cor-texto-minimo);
    font-size: 0.88rem;
    font-weight: 700;
    text-decoration: none;
  }

  .hero__linha {
    height: 1px;
    flex: 1;
    background: var(--cor-borda);
  }

  @media (min-width: 768px) {
    .hero {
      padding-inline: var(--espaco-8);
    }

    h1 {
      font-size: 6rem;
    }

    .hero__titulo {
      font-size: 1.45rem;
    }

    .hero__retrato {
      width: 360px;
    }
  }

  @media (min-width: 1024px) {
    .hero__interno {
      grid-template-columns: minmax(0, 1fr) minmax(300px, 360px);
      align-items: center;
      gap: var(--espaco-16);
    }

    h1 {
      font-size: 7.5rem;
    }

    .hero__visual {
      justify-content: flex-end;
    }
  }
</style>
