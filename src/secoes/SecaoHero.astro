---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import { perfil } from '../dados/perfil';

const imagens = import.meta.glob<{ default: ImageMetadata }>('/src/assets/imagens/*.{jpg,jpeg,png,webp,avif}', {
  eager: true
});

const chaveRetrato = perfil.retratoHeroArquivo
  ? `/src/assets/imagens/${perfil.retratoHeroArquivo}`
  : '';
const retrato = chaveRetrato ? imagens[chaveRetrato]?.default : undefined;
const [nomeHeroPrincipal = perfil.nome, ...nomeHeroComplemento] = perfil.nome.split(' ');
const nomeHeroSecundario = nomeHeroComplemento.join(' ');
---

<section id="home" class="hero" aria-labelledby="hero-title">
  <div class="hero__interno">
    <div class="hero__texto" data-aos="fade-up" data-aos-delay="80">
      <p class="hero__marcador">Portfolio &amp; Product Development Leader | Engineer | Expert in Materials Science</p>
      <h1 id="hero-title" aria-label={perfil.nome}>
        <span class="hero__nome-linha" aria-hidden="true">{nomeHeroPrincipal}</span>
        {nomeHeroSecundario && <span class="hero__nome-linha" aria-hidden="true">{nomeHeroSecundario}</span>}
      </h1>
      <p class="hero__titulo">{perfil.titulo}</p>
      <p class="hero__resumo">{perfil.resumoHero}</p>
    </div>

    <div class="hero__visual" data-aos="fade-up" data-aos-delay="180">
      <div class="hero__retrato">
        {retrato ? (
          <Image
            src={retrato}
            alt={perfil.retratoAlt}
            loading="eager"
            decoding="async"
            widths={[320, 480, 640, 760]}
            sizes="(min-width: 1280px) 500px, (min-width: 1024px) 440px, (min-width: 768px) 360px, 70vw"
            class="hero__imagem"
          />
        ) : (
          <div class="hero__retrato-vazio" aria-hidden="true"></div>
        )}
      </div>
    </div>
  </div>

  <div class="hero__indicador-scroll" aria-hidden="true">
    <svg viewBox="0 0 18 32" focusable="false">
      <path d="M9 2v22" />
      <path d="m4 19 5 5 5-5" />
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: grid;
    min-height: 100vh;
    min-height: 100svh;
    align-items: center;
    padding: var(--espaco-10) var(--espaco-5) calc(var(--altura-nav) + var(--espaco-8) + env(safe-area-inset-bottom));
    overflow: hidden;
    isolation: isolate;
    background: var(--cor-hero-fundo);
  }

  .hero::before,
  .hero::after {
    position: absolute;
    inset: 0;
    content: "";
    pointer-events: none;
  }

  .hero::before {
    z-index: -2;
    background:
      radial-gradient(circle at 79% 28%, rgba(0, 102, 204, 0.1), transparent 25rem),
      radial-gradient(circle at 14% 78%, rgba(255, 255, 255, 0.84), transparent 28rem),
      linear-gradient(135deg, var(--cor-hero-fundo) 0%, var(--cor-hero-fundo-frio) 52%, var(--cor-fundo-elevado) 100%);
  }

  .hero::after {
    z-index: -1;
    opacity: 0.78;
    background:
      linear-gradient(90deg, var(--cor-hero-linha) 1px, transparent 1px),
      linear-gradient(180deg, var(--cor-hero-linha) 1px, transparent 1px),
      linear-gradient(135deg, transparent 0 46%, var(--cor-hero-linha-forte) 46% 46.4%, transparent 46.4% 100%);
    background-position:
      center,
      center,
      calc(50% + 8px) calc(50% - 20px);
    background-size:
      72px 72px,
      72px 72px,
      180px 180px;
    -webkit-mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.9), transparent 86%);
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.9), transparent 86%);
  }

  .hero__interno {
    position: relative;
    z-index: 1;
    display: grid;
    width: min(100%, 1260px);
    align-items: center;
    margin-inline: auto;
    gap: var(--espaco-8);
  }

  .hero__texto {
    width: 100%;
    min-width: 0;
    max-width: 680px;
  }

  .hero__marcador {
    max-width: 34ch;
    margin: 0 0 var(--espaco-5);
    color: var(--cor-texto-minimo);
    font-size: 0.74rem;
    font-weight: 600;
    line-height: 1.45;
    text-transform: uppercase;
  }

  h1 {
    max-width: 8.8ch;
    margin: 0;
    font-family: var(--fonte-assinatura);
    font-size: clamp(1.85rem, 8.4vw, 3.05rem);
    font-weight: 400;
    line-height: 0.98;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .hero__nome-linha {
    display: block;
  }

  .hero__titulo {
    margin: var(--espaco-6) 0 0;
    color: var(--cor-texto);
    font-size: 1.08rem;
    font-weight: 620;
    line-height: 1.35;
    overflow-wrap: break-word;
  }

  .hero__resumo {
    max-width: 54ch;
    margin: var(--espaco-4) 0 0;
    color: var(--cor-texto-suave);
    font-size: 1rem;
    line-height: 1.6;
    overflow-wrap: break-word;
  }

  .hero__visual {
    position: relative;
    display: flex;
    justify-content: center;
    min-width: 0;
  }

  .hero__visual::before {
    content: none;
  }

  .hero__retrato {
    position: relative;
    z-index: 1;
    width: min(70vw, 248px);
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
    filter: none;
  }

  .hero__retrato::before,
  .hero__retrato::after {
    position: absolute;
    inset: -1px;
    z-index: 2;
    content: "";
    pointer-events: none;
  }

  .hero__retrato::before {
    background: linear-gradient(
      90deg,
      var(--cor-fundo-elevado) 0%,
      color-mix(in srgb, var(--cor-fundo-elevado) 88%, transparent) 6%,
      transparent 18%,
      transparent 82%,
      color-mix(in srgb, var(--cor-fundo-elevado) 88%, transparent) 94%,
      var(--cor-fundo-elevado) 100%
    );
  }

  .hero__retrato::after {
    background: linear-gradient(
      180deg,
      var(--cor-fundo-elevado) 0%,
      color-mix(in srgb, var(--cor-fundo-elevado) 76%, transparent) 7%,
      transparent 22%,
      transparent 64%,
      color-mix(in srgb, var(--cor-fundo-elevado) 72%, transparent) 84%,
      var(--cor-fundo-elevado) 100%
    );
  }

  .hero__imagem {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    filter: saturate(1.02) contrast(1.02);
    mix-blend-mode: multiply;
    object-fit: cover;
    object-position: 50% 20%;
  }

  .hero__indicador-scroll {
    position: absolute;
    bottom: calc(var(--altura-nav) + var(--espaco-6) + env(safe-area-inset-bottom));
    left: 50%;
    z-index: 2;
    display: inline-flex;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    color: var(--cor-texto);
    opacity: 0.48;
    pointer-events: none;
    transform: translateX(-50%);
  }

  .hero__indicador-scroll svg {
    width: 18px;
    height: 32px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.3;
    animation: indicador-scroll 1800ms ease-in-out infinite;
  }

  @keyframes indicador-scroll {
    0%,
    100% {
      opacity: 0.45;
      transform: translateY(-2px);
    }

    50% {
      opacity: 0.82;
      transform: translateY(4px);
    }
  }

  .hero__retrato-vazio {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(30deg, transparent 47%, var(--cor-borda-suave) 48%, var(--cor-borda-suave) 49%, transparent 50%),
      linear-gradient(150deg, transparent 47%, var(--cor-borda-suave) 48%, var(--cor-borda-suave) 49%, transparent 50%),
      var(--cor-superficie-forte);
    background-size: 96px 56px;
  }

  .hero__retrato-vazio::after {
    position: absolute;
    inset: var(--espaco-5);
    content: "";
    border: 1px solid var(--cor-borda);
    border-radius: 18px;
  }

  @media (min-width: 768px) {
    .hero {
      padding-inline: var(--espaco-8);
    }

    .hero::before {
      background:
        linear-gradient(
          90deg,
          transparent 0%,
          transparent 43%,
          color-mix(in srgb, var(--cor-fundo-elevado) 32%, transparent) 49%,
          color-mix(in srgb, var(--cor-fundo-elevado) 82%, transparent) 54%,
          var(--cor-fundo-elevado) 58%,
          var(--cor-fundo-elevado) 100%
        ),
        radial-gradient(circle at 79% 28%, rgba(0, 102, 204, 0.1), transparent 25rem),
        radial-gradient(circle at 14% 78%, rgba(255, 255, 255, 0.84), transparent 28rem),
        linear-gradient(135deg, var(--cor-hero-fundo) 0%, var(--cor-hero-fundo-frio) 52%, var(--cor-fundo-elevado) 100%);
    }

    .hero::after {
      -webkit-mask-image: linear-gradient(90deg, rgba(0, 0, 0, 0.9) 0%, rgba(0, 0, 0, 0.9) 43%, transparent 58%);
      mask-image: linear-gradient(90deg, rgba(0, 0, 0, 0.9) 0%, rgba(0, 0, 0, 0.9) 43%, transparent 58%);
    }

    .hero__interno {
      grid-template-columns: minmax(0, 1.15fr) minmax(260px, 0.85fr);
      justify-content: space-between;
      gap: var(--espaco-8);
    }

    .hero__texto {
      max-width: 500px;
    }

    h1 {
      max-width: 10ch;
      font-size: clamp(3.6rem, 6.7vw, 4.65rem);
    }

    .hero__titulo {
      font-size: 1.25rem;
    }

    .hero__resumo {
      font-size: 1.08rem;
    }

    .hero__marcador {
      max-width: 100%;
      font-size: 0.78rem;
    }

    .hero__retrato {
      width: min(100%, 360px);
    }
  }

  @media (min-width: 1024px) {
    .hero__interno {
      width: min(100%, 1260px);
      grid-template-columns: minmax(0, 1.2fr) minmax(330px, 0.8fr);
      align-items: center;
      justify-content: center;
      gap: clamp(var(--espaco-6), 3vw, var(--espaco-10));
    }

    .hero__texto {
      max-width: 720px;
    }

    h1 {
      max-width: none;
      font-size: clamp(4rem, 4.8vw, 5.08rem);
    }

    .hero__visual {
      justify-content: flex-end;
    }

    .hero__retrato {
      width: min(100%, 480px);
    }
  }

  @media (min-width: 1280px) {
    .hero__marcador {
      white-space: nowrap;
    }

    .hero__visual {
      margin-right: min(-4vw, -48px);
    }

    .hero__retrato {
      width: min(40vw, 520px);
    }

    .hero__titulo {
      max-width: 30ch;
    }

    .hero__resumo {
      max-width: 60ch;
    }
  }

  @media (max-width: 420px) {
    .hero {
      padding-top: var(--espaco-8);
    }

    .hero__interno {
      gap: var(--espaco-2);
    }

    .hero__marcador {
      margin-bottom: var(--espaco-4);
    }

    h1 {
      max-width: 100%;
      font-size: clamp(1.55rem, 7.2vw, 1.95rem);
    }

    .hero__retrato {
      width: min(52vw, 172px);
    }

    .hero__resumo {
      max-width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__indicador-scroll svg {
      animation: none;
    }
  }
</style>
