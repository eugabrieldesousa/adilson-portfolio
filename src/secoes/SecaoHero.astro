---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import { perfil } from '../dados/perfil';
import Botao from '../componentes/base/Botao.astro';
import Icone from '../componentes/base/Icone.astro';

const imagens = import.meta.glob<{ default: ImageMetadata }>('/src/assets/imagens/*.{jpg,jpeg,png,webp,avif}', {
  eager: true
});

const chaveRetrato = perfil.retratoHeroArquivo
  ? `/src/assets/imagens/${perfil.retratoHeroArquivo}`
  : '';
const retrato = chaveRetrato ? imagens[chaveRetrato]?.default : undefined;
---

<section id="home" class="hero" aria-labelledby="hero-title">
  <div class="hero__interno">
    <div class="hero__texto" data-aos="fade-up" data-aos-delay="80">
      <p class="hero__marcador">Portfolio · Engineering · Product Leadership</p>
      <h1 id="hero-title">{perfil.nome}</h1>
      <p class="hero__titulo">{perfil.titulo}</p>
      <p class="hero__resumo">{perfil.resumoHero}</p>
      <div class="hero__acoes" aria-label="Primary actions">
        <Botao href="#experience" variante="primario">
          Explore Experience
          <Icone nome="arrow-right" tamanho={17} />
        </Botao>
        <Botao href="#projects" variante="fantasma">View Selected Work</Botao>
      </div>
    </div>

    <div class="hero__visual" data-aos="fade-up" data-aos-delay="180">
      <div class="hero__retrato">
        {retrato ? (
          <Image
            src={retrato}
            alt={perfil.retratoAlt}
            loading="eager"
            decoding="async"
            widths={[320, 480, 640, 760]}
            sizes="(min-width: 1024px) 420px, (min-width: 768px) 380px, 82vw"
            class="hero__imagem"
          />
        ) : (
          <div class="hero__retrato-vazio" aria-hidden="true"></div>
        )}
      </div>
    </div>
  </div>

</section>

<style>
  .hero {
    position: relative;
    display: grid;
    min-height: 100vh;
    min-height: 100svh;
    align-items: center;
    padding: var(--espaco-8) var(--espaco-5) calc(var(--altura-nav) + var(--espaco-6) + env(safe-area-inset-bottom));
    overflow: hidden;
  }

  .hero__interno {
    display: grid;
    width: min(100%, 1060px);
    align-items: center;
    margin-inline: auto;
    gap: var(--espaco-5);
  }

  .hero__texto {
    min-width: 0;
    max-width: 540px;
  }

  .hero__marcador {
    margin: 0 0 var(--espaco-5);
    color: var(--cor-texto-minimo);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-family: var(--fonte-display);
    font-size: clamp(4rem, 17vw, 6rem);
    font-weight: 680;
    line-height: 0.98;
    letter-spacing: var(--tracking-display);
    overflow-wrap: break-word;
  }

  .hero__titulo {
    margin: var(--espaco-5) 0 0;
    color: var(--cor-texto);
    font-size: clamp(1.08rem, 3vw, 1.28rem);
    font-weight: 620;
    line-height: 1.35;
    overflow-wrap: break-word;
  }

  .hero__resumo {
    max-width: 48ch;
    margin: var(--espaco-4) 0 0;
    color: var(--cor-texto-suave);
    font-size: clamp(1rem, 2vw, 1.12rem);
    line-height: 1.6;
    overflow-wrap: break-word;
  }

  .hero__acoes {
    display: flex;
    flex-wrap: wrap;
    gap: var(--espaco-3);
    margin-top: var(--espaco-8);
  }

  .hero__visual {
    display: flex;
    justify-content: center;
  }

  .hero__retrato {
    position: relative;
    width: min(70vw, 240px);
    z-index: 0;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border: 0;
    border-radius: 42% 58% 48% 52% / 34% 38% 62% 66%;
    background: transparent;
    box-shadow: var(--sombra-retrato);
  }

  .hero__retrato::after {
    position: absolute;
    inset: 0;
    z-index: 2;
    content: "";
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.22), transparent 28%),
      linear-gradient(315deg, rgba(0, 102, 204, 0.08), transparent 34%);
    mix-blend-mode: screen;
    pointer-events: none;
  }

  .hero__imagem {
    width: 100%;
    height: auto;
    position: relative;
    z-index: 1;
    object-fit: cover;
    object-position: 50% 20%;
    mix-blend-mode: multiply;
  }

  .hero__retrato-vazio {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(30deg, transparent 47%, var(--cor-borda-suave) 48%, var(--cor-borda-suave) 49%, transparent 50%),
      linear-gradient(150deg, transparent 47%, var(--cor-borda-suave) 48%, var(--cor-borda-suave) 49%, transparent 50%),
      var(--cor-superficie-forte);
    background-size: 96px 56px;
  }

  .hero__retrato-vazio::after {
    position: absolute;
    inset: var(--espaco-5);
    content: "";
    border: 1px solid var(--cor-borda);
    border-radius: 18px;
  }

  @media (min-width: 768px) {
    .hero {
      padding-inline: var(--espaco-8);
    }

    h1 {
      font-size: clamp(5.5rem, 12vw, 7.5rem);
    }

    .hero__titulo {
      font-size: 1.25rem;
    }

    .hero__retrato {
      width: 400px;
    }
  }

  @media (min-width: 1024px) {
    .hero__interno {
      grid-template-columns: minmax(0, 500px) minmax(320px, 420px);
      align-items: center;
      justify-content: center;
      gap: var(--espaco-12);
    }

    h1 {
      font-size: clamp(6.5rem, 9vw, 8.75rem);
    }

    .hero__visual {
      justify-content: center;
    }

    .hero__retrato {
      width: 440px;
    }
  }
</style>
