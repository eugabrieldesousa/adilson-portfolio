---
import { perfil } from '../dados/perfil';
import Icone from '../componentes/base/Icone.astro';

const contatos = [
  {
    rotulo: 'Email',
    valor: perfil.links.email,
    href: perfil.links.email ? `mailto:${perfil.links.email}` : undefined,
    icone: 'mail' as const
  },
  {
    rotulo: 'LinkedIn',
    valor: 'Professional profile',
    href: perfil.links.linkedin || undefined,
    icone: 'linkedin' as const,
    externo: true
  },
  {
    rotulo: 'Location',
    valor: perfil.localizacao,
    icone: 'location' as const
  }
].filter((contato) => contato.valor);
---

<section id="contact" class="contato" aria-labelledby="contact-title">
  <div class="contato__interno" data-aos="fade-up">
    <header class="contato__cabecalho">
      <p class="contato__marcador">Contact</p>
      <h2 id="contact-title">Building Innovation Through Leadership and Execution</h2>
      <p class="contato__descricao">
        I welcome conversations about engineering leadership, portfolio management, product innovation, materials science, and business transformation.
      </p>
    </header>

    <div class="contato__informacoes" aria-label="Contact information">
      {
        contatos.map((contato) => {
          const conteudo = (
            <>
              <span class="contato__icone">
                <Icone nome={contato.icone} tamanho={20} />
              </span>
              <span class="contato__texto">
                <span class="contato__rotulo">{contato.rotulo}</span>
                <strong>{contato.valor}</strong>
              </span>
              {contato.href && (
                <span class="contato__seta" aria-hidden="true">
                  <Icone nome={contato.externo ? 'external-link' : 'arrow-right'} tamanho={18} />
                </span>
              )}
            </>
          );

          return contato.href ? (
            <a
              class="contato__item contato__item--link"
              href={contato.href}
              target={contato.externo ? '_blank' : undefined}
              rel={contato.externo ? 'noreferrer' : undefined}
            >
              {conteudo}
            </a>
          ) : (
            <div class="contato__item">{conteudo}</div>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .contato {
    position: relative;
    padding:
      clamp(var(--espaco-20), 9vw, 8rem)
      var(--espaco-5)
      clamp(var(--espaco-20), 8vw, 7rem);
    overflow: hidden;
    border-top: 1px solid var(--cor-borda-suave);
    background:
      linear-gradient(180deg, rgba(0, 102, 204, 0.035), transparent 42%),
      var(--cor-fundo-elevado);
    color: var(--cor-texto);
  }

  .contato__interno {
    display: grid;
    width: min(100%, var(--largura-conteudo));
    margin-inline: auto;
    gap: var(--espaco-12);
  }

  .contato__cabecalho {
    max-width: 680px;
  }

  .contato__marcador {
    margin: 0 0 var(--espaco-4);
    color: var(--cor-acento);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  h2 {
    max-width: 18ch;
    margin: 0;
    font-family: var(--fonte-display);
    font-size: clamp(2.5rem, 4.5vw, 4rem);
    font-weight: 650;
    line-height: 0.98;
    letter-spacing: var(--tracking-titulo);
    text-wrap: balance;
  }

  .contato__descricao {
    max-width: 57ch;
    margin: var(--espaco-6) 0 0;
    color: var(--cor-texto-suave);
    font-size: clamp(1rem, 1.5vw, 1.16rem);
    line-height: 1.65;
  }

  .contato__informacoes {
    align-self: center;
    border-top: 1px solid var(--cor-borda);
  }

  .contato__item {
    display: grid;
    min-height: 92px;
    grid-template-columns: 40px minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--espaco-4);
    border-bottom: 1px solid var(--cor-borda);
    color: var(--cor-texto);
  }

  .contato__item--link {
    text-decoration: none;
    transition:
      color 180ms ease,
      padding-inline 180ms ease;
  }

  .contato__item--link:hover,
  .contato__item--link:focus-visible {
    padding-inline: var(--espaco-3);
    color: var(--cor-acento);
  }

  .contato__icone {
    display: grid;
    width: 40px;
    height: 40px;
    place-items: center;
    border: 1px solid var(--cor-borda);
    border-radius: 50%;
    color: var(--cor-acento);
  }

  .contato__texto {
    display: grid;
    min-width: 0;
    gap: var(--espaco-1);
  }

  .contato__rotulo {
    color: var(--cor-texto-minimo);
    font-size: 0.76rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .contato__texto strong {
    overflow-wrap: anywhere;
    font-size: clamp(1rem, 1.6vw, 1.18rem);
    font-weight: 620;
  }

  .contato__seta {
    display: grid;
    place-items: center;
    color: var(--cor-texto-minimo);
  }

  @media (min-width: 768px) {
    .contato {
      padding-inline: var(--espaco-8);
    }
  }

  @media (min-width: 1024px) {
    .contato__interno {
      grid-template-columns: minmax(0, 1.3fr) minmax(360px, 0.7fr);
      align-items: center;
      gap: clamp(var(--espaco-16), 6vw, var(--espaco-24));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contato__item--link {
      transition: none;
    }
  }
</style>
