---
import { getCollection } from 'astro:content';
import Secao from '../componentes/base/Secao.astro';
import Etiqueta from '../componentes/base/Etiqueta.astro';

const experiencias = (await getCollection('experiencias', ({ data }) => !data.rascunho)).sort(
  (atual, proxima) => atual.data.ordem - proxima.data.ordem
);
---

<Secao
  id="experience"
  titulo="Experience built across strategy and engineering"
  marcador="Career progression"
  descricao="A progression from laboratory research and product development to materials leadership and North American portfolio management."
>
  <div class="experiencia" data-experiencia-timeline>
    <div class="experiencia__linha" aria-hidden="true">
      <span data-experiencia-progresso></span>
    </div>

    <ol class="experiencia__lista" aria-label="Professional experience timeline">
      {
        experiencias.map(({ data }, indice) => (
          <li class="experiencia__item" data-experiencia-item>
            <p class="experiencia__periodo experiencia__periodo--externo">{data.periodo}</p>

            <div class="experiencia__marcador" aria-hidden="true">
              <span>{String(indice + 1).padStart(2, '0')}</span>
            </div>

            <article class="experiencia__cartao">
              <p class="experiencia__periodo experiencia__periodo--interno">{data.periodo}</p>
              {data.organizacao && <p class="experiencia__organizacao">{data.organizacao}</p>}
              <h3>{data.titulo}</h3>
              {data.localizacao && <p class="experiencia__localizacao">{data.localizacao}</p>}
              {data.resumo && <p class="experiencia__resumo">{data.resumo}</p>}

              {data.competencias.length > 0 && (
                <ul class="experiencia__competencias" aria-label={`Key focus areas for ${data.titulo}`}>
                  {data.competencias.map((competencia) => (
                    <li>
                      <Etiqueta texto={competencia} variante="competencia" />
                    </li>
                  ))}
                </ul>
              )}
            </article>
          </li>
        ))
      }
    </ol>
  </div>
</Secao>

<style>
  .experiencia {
    position: relative;
    max-width: 980px;
    margin-top: var(--espaco-2);
  }

  .experiencia__linha {
    position: absolute;
    top: var(--espaco-2);
    bottom: var(--espaco-2);
    left: 15px;
    width: 1px;
    overflow: hidden;
    background: var(--cor-borda);
  }

  .experiencia__linha > span {
    position: absolute;
    inset: 0;
    display: block;
    background: linear-gradient(180deg, var(--cor-acento), color-mix(in srgb, var(--cor-acento) 42%, var(--cor-texto)));
    transform-origin: top center;
  }

  .experiencia__lista {
    display: grid;
    gap: var(--espaco-5);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .experiencia__item {
    position: relative;
    display: grid;
    grid-template-columns: 32px minmax(0, 1fr);
    gap: var(--espaco-4);
    min-width: 0;
  }

  .experiencia__periodo {
    margin: 0;
    color: var(--cor-texto-minimo);
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1.25;
  }

  .experiencia__periodo--externo {
    display: none;
  }

  .experiencia__periodo--interno {
    margin-bottom: var(--espaco-2);
  }

  .experiencia__marcador {
    position: relative;
    z-index: 1;
    display: grid;
    width: 32px;
    height: 32px;
    place-items: center;
    border: 1px solid var(--cor-borda);
    border-radius: var(--raio-pilula);
    background: var(--cor-fundo-elevado);
    box-shadow: 0 8px 22px rgba(29, 29, 31, 0.08);
  }

  .experiencia__marcador span {
    color: var(--cor-acento);
    font-size: 0.68rem;
    font-weight: 800;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .experiencia__cartao {
    min-width: 0;
    border: 1px solid var(--cor-borda);
    border-radius: var(--raio-medio);
    padding: var(--espaco-5);
    background: var(--cor-superficie);
    box-shadow: var(--sombra-suave);
  }

  .experiencia__organizacao {
    margin: 0;
    color: var(--cor-acento);
    font-size: 0.88rem;
    font-weight: 700;
    line-height: 1.3;
  }

  h3 {
    max-width: 28ch;
    margin: var(--espaco-2) 0 0;
    font-family: var(--fonte-display);
    font-size: 1.28rem;
    font-weight: 650;
    line-height: 1.13;
    letter-spacing: var(--tracking-titulo);
    text-wrap: balance;
  }

  .experiencia__localizacao,
  .experiencia__resumo {
    max-width: 66ch;
    margin: var(--espaco-3) 0 0;
    color: var(--cor-texto-suave);
    font-size: 0.96rem;
  }

  .experiencia__localizacao {
    color: var(--cor-texto-minimo);
    font-size: 0.9rem;
  }

  .experiencia__competencias {
    display: flex;
    flex-wrap: wrap;
    gap: var(--espaco-2);
    margin: var(--espaco-4) 0 0;
    padding: 0;
    list-style: none;
  }

  .experiencia__competencias li {
    min-width: 0;
  }

  @media (min-width: 768px) {
    .experiencia__linha {
      left: 151px;
    }

    .experiencia__lista {
      gap: var(--espaco-6);
    }

    .experiencia__item {
      grid-template-columns: 128px 48px minmax(0, 1fr);
      gap: var(--espaco-3);
      align-items: start;
    }

    .experiencia__periodo--externo {
      display: block;
      padding-top: var(--espaco-2);
      text-align: right;
    }

    .experiencia__periodo--interno {
      display: none;
    }

    .experiencia__marcador {
      width: 48px;
      height: 48px;
    }

    .experiencia__cartao {
      padding: var(--espaco-6);
    }

    h3 {
      font-size: 1.52rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .experiencia__linha > span,
    .experiencia__item,
    .experiencia__cartao,
    .experiencia__marcador {
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

<script>
  let contextoExperiencia: { revert: () => void } | undefined;

  const iniciarTimelineExperiencia = async () => {
    contextoExperiencia?.revert();

    const movimentoReduzido = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const timelines = document.querySelectorAll('[data-experiencia-timeline]');

    if (movimentoReduzido || timelines.length === 0) return;

    const [{ default: gsap }, { ScrollTrigger }] = await Promise.all([
      import('gsap'),
      import('gsap/ScrollTrigger')
    ]);

    gsap.registerPlugin(ScrollTrigger);

    contextoExperiencia = gsap.context(() => {
      timelines.forEach((timeline) => {
        const progresso = timeline.querySelector('[data-experiencia-progresso]');
        const itens = Array.from(timeline.querySelectorAll('[data-experiencia-item]'));

        if (!progresso || itens.length === 0) return;

        gsap.set(progresso, { scaleY: 0, transformOrigin: 'top center' });

        gsap.to(progresso, {
          scaleY: 1,
          ease: 'none',
          scrollTrigger: {
            trigger: timeline,
            start: 'top 68%',
            end: 'bottom 62%',
            scrub: 0.35
          }
        });

        itens.forEach((item) => {
          const cartao = item.querySelector('.experiencia__cartao');
          const marcador = item.querySelector('.experiencia__marcador');

          gsap.fromTo(
            [cartao, marcador].filter(Boolean),
            { autoAlpha: 0, y: 30 },
            {
              autoAlpha: 1,
              y: 0,
              duration: 0.5,
              ease: 'power2.out',
              stagger: 0.06,
              scrollTrigger: {
                trigger: item,
                start: 'top 78%',
                toggleActions: 'play none none reverse'
              }
            }
          );
        });
      });
    });

    ScrollTrigger.refresh();
  };

  const iniciarAposIntro = () => {
    const observarExperiencia = () => {
      const alvo = document.querySelector('[data-experiencia-timeline]');

      if (!alvo || !('IntersectionObserver' in window)) {
        iniciarTimelineExperiencia();
        return;
      }

      const observador = new IntersectionObserver(
        (entradas) => {
          if (!entradas.some((entrada) => entrada.isIntersecting)) return;
          observador.disconnect();
          iniciarTimelineExperiencia();
        },
        { rootMargin: '35% 0px' }
      );

      observador.observe(alvo);
    };

    if (document.documentElement.classList.contains('intro-ativa')) {
      window.addEventListener('intro:complete', observarExperiencia, { once: true });
      return;
    }

    observarExperiencia();
  };

  iniciarAposIntro();
  document.addEventListener('astro:after-swap', iniciarAposIntro);
</script>
