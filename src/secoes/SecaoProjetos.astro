---
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import Secao from '../componentes/base/Secao.astro';
import ModalProjeto from '../componentes/portfolio/ModalProjeto.astro';

const entradasProjetos = (await getCollection('projetos', ({ data }) => !data.rascunho)).sort(
  (atual, proxima) => atual.data.ordem - proxima.data.ordem
);

const projetos = await Promise.all(
  entradasProjetos.map(async (projeto) => ({
    ...projeto,
    Conteudo: (await render(projeto)).Content
  }))
);

const alturaBaseImagemCard = 500;
---

<Secao
  id="projects"
  titulo="Selected Product & Engineering Programs"
  marcador="Product portfolio"
  descricao="Leading complex global initiatives from concept development through commercialization, operational readiness, and value realization."
  alinhamento="centro"
  fundoSolido
>
  <div class="projetos" data-projetos>
    {
      projetos.map(({ id, data, Conteudo }) => {
        const modalId = `modal-projeto-${id.replace(/[^a-zA-Z0-9_-]/g, '-')}`;
        const alturaImagemCard = data.alturaImagemCard ?? alturaBaseImagemCard;
        const deslocamentoImagemCard = alturaBaseImagemCard - alturaImagemCard;
        const respiroImagemCard = Math.abs(deslocamentoImagemCard);
        const margemImagemCard = -respiroImagemCard;
        const alturaExtraImagemCard = respiroImagemCard * 2;

        return (
          <>
            <article
              class={`projetos__cartao projetos__cartao--${data.tema}`}
              style={`--altura-imagem-card: ${alturaImagemCard}px; --deslocamento-imagem-card: ${deslocamentoImagemCard}px; --margem-imagem-card: ${margemImagemCard}px; --altura-extra-imagem-card: ${alturaExtraImagemCard}px;`}
            >
              <div
                class="projetos__visual"
              >
                <Image
                  src={data.imagemCard}
                  alt={data.imagemCardAlt}
                  widths={[480, 720, 960]}
                  sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw"
                  format="webp"
                  loading="lazy"
                  decoding="async"
                />
              </div>

              <div class="projetos__texto">
                <h3
                  class:list={[
                    'projetos__titulo',
                    { 'projetos__titulo--longo': data.titulo.length > 56 }
                  ]}
                >
                  {data.titulo}
                </h3>

                <button
                  class="projetos__acao"
                  type="button"
                  aria-label={`View details for ${data.titulo}`}
                  aria-controls={modalId}
                  aria-haspopup="dialog"
                  data-modal-abrir={modalId}
                >
                  View
                </button>
              </div>
            </article>

            <ModalProjeto
              id={modalId}
              titulo={data.tituloModal ?? data.titulo}
              resumo={data.resumoModal ?? data.resumo}
              midia={data.midiaModal}
              tema={data.temaModal ?? data.tema}
              url={data.url}
              rotuloLink={data.rotuloLink}
            >
              <Conteudo />
            </ModalProjeto>
          </>
        );
      })
    }
  </div>
</Secao>

<style>
  :global(#projects) {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding-block: clamp(var(--espaco-12), 5vw, var(--espaco-16));
    background: var(--cor-fundo-elevado);
  }

  :global(#projects)::before {
    position: absolute;
    inset: 0;
    z-index: -1;
    content: "";
    background:
      radial-gradient(circle at 50% 3%, rgba(0, 113, 227, 0.09), transparent 25rem),
      var(--cor-fundo-elevado);
  }

  :global(#projects .secao__cabecalho) {
    max-width: 900px;
    margin-bottom: clamp(var(--espaco-10), 6vw, var(--espaco-16));
  }

  :global(#projects .secao__cabecalho h2) {
    margin-top: var(--espaco-4);
    max-width: 18ch;
    margin-inline: auto;
    font-size: clamp(2.65rem, 5.7vw, 5.25rem);
    font-weight: 650;
    line-height: 0.94;
    text-wrap: balance;
  }

  :global(#projects .secao__cabecalho > p:last-child) {
    max-width: 66ch;
    margin: var(--espaco-6) auto 0;
    font-size: clamp(1rem, 1.5vw, 1.18rem);
    line-height: 1.55;
  }

  .projetos {
    display: grid;
    width: calc(100vw - 20px);
    margin-left: calc(50% - 50vw + 10px);
    grid-template-columns: minmax(0, 1fr);
    gap: 10px;
  }

  .projetos__cartao {
    --projeto-fundo: var(--cor-projeto-azul-meio);
    --projeto-texto: var(--cor-projeto-azul-texto);
    --projeto-botao-fundo: var(--cor-projeto-azul-texto);
    --projeto-botao-texto: var(--cor-projeto-claro-texto);
    position: relative;
    display: grid;
    width: 100%;
    min-width: 0;
    aspect-ratio: 8 / 9;
    overflow: hidden;
    border-radius: var(--raio-medio);
    background: var(--projeto-fundo);
    color: var(--projeto-texto);
    box-shadow: 0 16px 42px rgba(29, 29, 31, 0.08);
    text-align: center;
  }

  .projetos__cartao--claro {
    --projeto-fundo: var(--cor-projeto-claro);
    --projeto-texto: var(--cor-projeto-claro-texto);
    --projeto-botao-fundo: var(--cor-projeto-claro-texto);
    --projeto-botao-texto: var(--cor-projeto-claro);
  }

  .projetos__cartao--preto {
    --projeto-fundo: var(--cor-projeto-preto);
    --projeto-texto: var(--cor-projeto-preto-texto);
    --projeto-botao-fundo: var(--cor-projeto-preto-texto);
    --projeto-botao-texto: var(--cor-projeto-preto);
  }

  .projetos__texto {
    position: absolute;
    inset: clamp(2rem, 4.5vw, 3.5rem) var(--espaco-5) auto;
    z-index: 2;
    display: flex;
    min-height: clamp(168px, 29%, 230px);
    flex-direction: column;
    align-items: center;
    justify-items: center;
    gap: var(--espaco-3);
    pointer-events: none;
  }

  .projetos__titulo {
    display: -webkit-box;
    width: 100%;
    height: 3.12em;
    margin: 0;
    max-width: 24ch;
    min-height: 3.12em;
    max-height: 3.12em;
    flex: 0 0 3.12em;
    overflow: hidden;
    font-family: var(--fonte-display);
    font-size: clamp(1.65rem, 7vw, 2.8rem);
    font-weight: 650;
    line-height: 1.04;
    letter-spacing: var(--tracking-titulo);
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    text-wrap: balance;
  }

  .projetos__titulo--longo {
    height: 3.25em;
    min-height: 3.25em;
    max-height: 3.25em;
    flex-basis: 3.25em;
    font-size: clamp(1.45rem, 6.2vw, 2.45rem);
  }

  .projetos__acao {
    display: inline-flex;
    min-width: 88px;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: var(--raio-pilula);
    padding: 0 var(--espaco-5);
    background: var(--projeto-botao-fundo);
    color: var(--projeto-botao-texto);
    font-weight: 600;
    line-height: 1;
    cursor: pointer;
    pointer-events: auto;
    touch-action: manipulation;
    transition:
      background-color 220ms ease,
      box-shadow 220ms ease,
      opacity 220ms ease;
  }

  .projetos__visual {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
    width: 100%;
    height: 100%;
    min-width: 0;
    overflow: hidden;
    background: transparent;
    pointer-events: none;
  }

  .projetos__visual :global(img) {
    display: block;
    position: absolute;
    inset: var(--margem-imagem-card, 0px) 0;
    width: 100%;
    height: calc(100% + var(--altura-extra-imagem-card, 0px));
    object-fit: cover;
    object-position: center center;
    transform: translateY(var(--deslocamento-imagem-card, 0px));
  }

  .projetos__acao:hover,
  .projetos__acao:focus-visible {
    box-shadow: 0 8px 24px color-mix(in srgb, var(--projeto-texto) 18%, transparent);
    opacity: 0.82;
  }

  .projetos__acao:active {
    opacity: 0.7;
  }

  @media (min-width: 768px) {
    .projetos {
      width: calc(100vw - 24px);
      margin-left: calc(50% - 50vw + 12px);
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .projetos__cartao {
      aspect-ratio: 8 / 9;
    }

    .projetos__titulo {
      font-size: clamp(1.65rem, 3.35vw, 2.55rem);
    }

    .projetos__titulo--longo {
      font-size: clamp(1.45rem, 2.85vw, 2.15rem);
    }
  }

  @media (min-width: 1024px) {
    .projetos {
      width: calc(100vw - 32px);
      margin-left: calc(50% - 50vw + 16px);
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .projetos__cartao {
      aspect-ratio: 8 / 9;
    }

    .projetos__texto {
      inset: var(--espaco-8) var(--espaco-6) auto;
      min-height: 178px;
    }

    .projetos__titulo {
      font-size: clamp(1.35rem, 2.05vw, 2rem);
    }

    .projetos__titulo--longo {
      font-size: clamp(1.2rem, 1.75vw, 1.7rem);
    }

  }

  @media (min-width: 1440px) {
    .projetos {
      gap: 14px;
    }

    .projetos__texto {
      inset: var(--espaco-10) var(--espaco-8) auto;
      min-height: 198px;
    }

    .projetos__titulo {
      font-size: clamp(1.65rem, 1.85vw, 2.35rem);
    }

    .projetos__titulo--longo {
      font-size: clamp(1.4rem, 1.58vw, 2rem);
    }
  }

  @media (max-width: 420px) {
    .projetos__texto {
      inset-inline: var(--espaco-4);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .projetos__acao {
      transition: none;
    }
  }
</style>

<script>
  const iniciarModaisProjetos = () => {
    const raiz = document.querySelector<HTMLElement>('[data-projetos]');

    if (!raiz || raiz.dataset.modaisInicializadas === 'true') {
      return;
    }

    raiz.dataset.modaisInicializadas = 'true';

    let gatilhoAtual: HTMLElement | null = null;
    let temporizadorFechamento: number | undefined;
    const movimentoReduzido = window.matchMedia('(prefers-reduced-motion: reduce)');

    const concluirFechamento = (dialogo: HTMLDialogElement) => {
      window.clearTimeout(temporizadorFechamento);
      dialogo.classList.remove('modal-projeto--fechando');
      dialogo.querySelectorAll<HTMLVideoElement>('[data-modal-video]').forEach((video) => {
        video.pause();
      });

      if (dialogo.open) {
        dialogo.close();
      }
    };

    const fecharModal = (dialogo: HTMLDialogElement, animar = true) => {
      if (!dialogo.open || dialogo.classList.contains('modal-projeto--fechando')) {
        return;
      }

      if (!animar || movimentoReduzido.matches) {
        concluirFechamento(dialogo);
        return;
      }

      dialogo.classList.add('modal-projeto--fechando');
      temporizadorFechamento = window.setTimeout(() => concluirFechamento(dialogo), 170);
    };

    const abrirModal = (id: string, gatilho: HTMLElement) => {
      const dialogo = document.getElementById(id);

      if (!(dialogo instanceof HTMLDialogElement)) {
        return;
      }

      gatilhoAtual = gatilho;
      document.documentElement.classList.add('modal-projeto-ativa');
      document.dispatchEvent(new CustomEvent('rolagem-suave:parar'));
      dialogo.showModal();

      window.requestAnimationFrame(() => {
        const painel = dialogo.querySelector<HTMLElement>('[data-modal-painel]');
        const conteudo = dialogo.querySelector<HTMLElement>('[data-modal-conteudo]');

        if (painel) {
          painel.scrollTop = 0;
        }

        if (conteudo) {
          conteudo.scrollTop = 0;
        }

        if (!movimentoReduzido.matches) {
          dialogo.querySelectorAll<HTMLVideoElement>('[data-modal-video]').forEach((video) => {
            void video.play().catch(() => undefined);
          });
        }

        dialogo.querySelector<HTMLElement>('[data-modal-fechar]')?.focus();
      });
    };

    raiz.addEventListener('click', (evento) => {
      const alvo = evento.target;

      if (!(alvo instanceof Element)) {
        return;
      }

      const gatilho = alvo.closest<HTMLElement>('[data-modal-abrir]');

      if (gatilho) {
        const modalId = gatilho.dataset.modalAbrir;

        if (modalId) {
          abrirModal(modalId, gatilho);
        }

        return;
      }

      const dialogo = alvo.closest<HTMLDialogElement>('[data-modal-projeto]');

      if (!dialogo) {
        return;
      }

      if (alvo.closest('[data-modal-fechar]')) {
        fecharModal(dialogo);
        return;
      }

      if (alvo.closest('[data-modal-link]')) {
        fecharModal(dialogo, false);
        return;
      }

      if (alvo === dialogo) {
        fecharModal(dialogo);
      }
    });

    raiz.querySelectorAll<HTMLDialogElement>('[data-modal-projeto]').forEach((dialogo) => {
      dialogo.addEventListener('cancel', (evento) => {
        evento.preventDefault();
        fecharModal(dialogo);
      });

      dialogo.addEventListener('close', () => {
        document.documentElement.classList.remove('modal-projeto-ativa');
        document.dispatchEvent(new CustomEvent('rolagem-suave:iniciar'));
        gatilhoAtual?.focus();
        gatilhoAtual = null;
      });
    });
  };

  iniciarModaisProjetos();
  document.addEventListener('astro:after-swap', iniciarModaisProjetos);
</script>
