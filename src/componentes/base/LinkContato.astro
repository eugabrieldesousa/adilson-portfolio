---
import Icone from './Icone.astro';

interface Props {
  href: string;
  rotulo: string;
  tipo: 'mail' | 'phone' | 'linkedin' | 'file';
  detalhe?: string;
  externo?: boolean;
  download?: boolean | string;
  variante?: 'padrao' | 'claro';
}

const { href, rotulo, tipo, detalhe, externo = false, download, variante = 'padrao' } = Astro.props;
const rel = externo ? 'noreferrer' : undefined;
const target = externo ? '_blank' : undefined;
---

<a
  class:list={['link-contato', { 'link-contato--claro': variante === 'claro' }]}
  href={href}
  target={target}
  rel={rel}
  download={download}
>
  <span class="link-contato__icone"><Icone nome={tipo} tamanho={20} /></span>
  <span class="link-contato__texto">
    {detalhe && <span class="link-contato__detalhe">{detalhe}</span>}
    <span>{rotulo}</span>
  </span>
  {variante === 'claro' && <span class="link-contato__seta" aria-hidden="true">↗</span>}
</a>

<style>
  .link-contato {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: var(--espaco-2);
    border-bottom: 1px solid transparent;
    color: var(--cor-acento);
    font-weight: 600;
    text-decoration: none;
    transition:
      background-color 180ms ease,
      border-color 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .link-contato__icone {
    display: grid;
    flex: 0 0 auto;
    place-items: center;
  }

  .link-contato__texto {
    display: grid;
    min-width: 0;
    gap: 0.2rem;
  }

  .link-contato__detalhe {
    color: var(--cor-contato-texto-suave);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .link-contato:hover {
    border-bottom-color: currentColor;
  }

  .link-contato--claro {
    display: grid;
    min-height: 116px;
    grid-template-columns: 48px minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--espaco-4);
    border: 1px solid var(--cor-contato-borda);
    border-radius: var(--raio-contato);
    padding: var(--espaco-5);
    background: var(--cor-contato-superficie);
    color: var(--cor-contato-texto);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.14);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .link-contato--claro .link-contato__icone {
    width: 48px;
    height: 48px;
    border: 1px solid var(--cor-contato-borda);
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
  }

  .link-contato--claro .link-contato__texto > :last-child {
    overflow-wrap: anywhere;
    font-size: clamp(1rem, 2vw, 1.18rem);
  }

  .link-contato__seta {
    color: var(--cor-contato-texto-suave);
    font-size: 1.25rem;
    transition: transform 180ms ease;
  }

  .link-contato--claro:hover,
  .link-contato--claro:focus-visible {
    border-color: rgba(255, 255, 255, 0.48);
    background: rgba(255, 255, 255, 0.22);
    transform: translateY(-2px);
  }

  .link-contato--claro:hover .link-contato__seta,
  .link-contato--claro:focus-visible .link-contato__seta {
    transform: translate(2px, -2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .link-contato {
      transition: none;
    }

    .link-contato--claro:hover,
    .link-contato--claro:focus-visible,
    .link-contato__seta {
      transform: none;
    }
  }
</style>
