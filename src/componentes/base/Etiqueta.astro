---
interface Props {
  texto: string;
}

const { texto } = Astro.props;
---

<span class="etiqueta">{texto}</span>

<style>
  .etiqueta {
    display: inline-flex;
    min-height: 32px;
    align-items: center;
    border: 1px solid var(--cor-borda);
    border-radius: var(--raio-pilula);
    padding: var(--espaco-1) var(--espaco-3);
    background: var(--cor-superficie);
    color: var(--cor-texto);
    font-size: 0.86rem;
    font-weight: 500;
    line-height: 1.2;
  }
</style>
