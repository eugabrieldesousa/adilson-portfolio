---
import 'aos/dist/aos.css';
---

<script>
  // @ts-ignore AOS does not ship TypeScript declarations.
  import AOS from 'aos';

  let aosIniciado = false;

  const movimentoReduzido = () =>
    window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const iniciarAOS = () => {
    if (aosIniciado) {
      AOS.refreshHard();
      return;
    }

    aosIniciado = true;
    AOS.init({
      duration: 650,
      easing: 'ease-out-cubic',
      offset: 80,
      once: true,
      mirror: false,
      disable: movimentoReduzido
    });

    window.setTimeout(() => AOS.refreshHard(), 80);
  };

  if (document.documentElement.classList.contains('intro-ativa')) {
    window.addEventListener('intro:complete', iniciarAOS, { once: true });
    window.setTimeout(() => {
      if (!aosIniciado) iniciarAOS();
    }, 3600);
  } else {
    iniciarAOS();
  }
</script>

<style is:global>
  [data-aos] {
    will-change: transform, opacity;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-aos] {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>
