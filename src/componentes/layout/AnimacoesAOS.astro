---
import 'aos/dist/aos.css';
---

<script>
  let aosIniciado = false;

  const movimentoReduzido = () =>
    window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const iniciarAOS = async () => {
    const { default: AOS } = await import('aos');

    if (aosIniciado) {
      AOS.refreshHard();
      return;
    }

    aosIniciado = true;
    AOS.init({
      duration: 650,
      easing: 'ease-out-cubic',
      offset: 80,
      once: true,
      mirror: false,
      disable: movimentoReduzido
    });

    window.setTimeout(() => AOS.refreshHard(), 80);
  };

  const iniciarAposIntro = () => {
    if (document.documentElement.classList.contains('intro-ativa')) {
      window.addEventListener('intro:complete', iniciarAOS, { once: true });
      return;
    }

    iniciarAOS();
  };

  iniciarAposIntro();
  document.addEventListener('astro:after-swap', iniciarAposIntro);
</script>

<style is:global>
  [data-aos] {
    will-change: transform, opacity;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-aos] {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>
