---
import 'aos/dist/aos.css';
---

<script>
  import AOS from 'aos';

  let aosIniciado = false;
  let temporizadorFallback: number | undefined;

  const iniciarAOS = () => {
    if (aosIniciado) {
      AOS.refreshHard();
      return;
    }

    aosIniciado = true;
    AOS.init({
      duration: 650,
      easing: 'ease-out-cubic',
      offset: 80,
      once: true,
      mirror: false
    });

    window.setTimeout(() => AOS.refreshHard(), 80);
  };

  const iniciarAposIntro = () => {
    window.clearTimeout(temporizadorFallback);

    if (document.documentElement.classList.contains('intro-ativa')) {
      let iniciado = false;
      const iniciar = () => {
        if (iniciado) return;
        iniciado = true;
        window.clearTimeout(temporizadorFallback);
        iniciarAOS();
      };

      window.addEventListener('intro:complete', iniciar, { once: true });
      temporizadorFallback = window.setTimeout(iniciar, 3600);
      return;
    }

    iniciarAOS();
  };

  iniciarAposIntro();
  document.addEventListener('astro:after-swap', iniciarAposIntro);
</script>

<style is:global>
  [data-aos] {
    will-change: transform, opacity;
  }
</style>
