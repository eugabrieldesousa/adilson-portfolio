---
import { navegacao } from '../../dados/navegacao';
---

<header class="cabecalho-site">
  <nav class="navegacao" aria-label="Primary navigation">
    <ul class="navegacao__lista">
      {navegacao.map((item) => (
        <li>
          <a
            class:list={['navegacao__link', { 'navegacao__link--ativo': item.href === '#home' }]}
            href={item.href}
            data-nav-link={item.href}
            aria-current={item.href === '#home' ? 'location' : undefined}
          >
            <span>{item.rotulo}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .cabecalho-site {
    position: fixed;
    right: 0;
    bottom: calc(var(--espaco-4) + env(safe-area-inset-bottom));
    left: 0;
    z-index: var(--z-nav);
    display: flex;
    justify-content: center;
    padding-inline: var(--espaco-4);
    pointer-events: none;
  }

  .navegacao {
    position: relative;
    max-width: min(100%, 620px);
    min-height: var(--altura-nav);
    border: 1px solid var(--cor-nav-borda);
    border-radius: var(--raio-pilula);
    background: var(--cor-nav);
    box-shadow: var(--sombra-nav);
    color: var(--cor-nav-texto);
    pointer-events: auto;
    backdrop-filter: blur(22px) saturate(160%);
    -webkit-backdrop-filter: blur(22px) saturate(160%);
    outline: 1px solid rgba(255, 255, 255, 0.14);
    outline-offset: -2px;
  }

  .navegacao::before {
    position: absolute;
    inset: 1px;
    content: "";
    border-radius: inherit;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.2), transparent 46%),
      linear-gradient(90deg, rgba(255, 255, 255, 0.1), transparent 22%, transparent 78%, rgba(255, 255, 255, 0.1));
    pointer-events: none;
  }

  .navegacao__lista {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--espaco-1);
    height: 100%;
    margin: 0;
    padding: var(--espaco-2);
    list-style: none;
  }

  .navegacao__link {
    display: inline-flex;
    min-width: 44px;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    gap: var(--espaco-2);
    border-radius: var(--raio-pilula);
    padding: 0 var(--espaco-4);
    color: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1;
    text-decoration: none;
    touch-action: manipulation;
    transition:
      background-color 180ms ease,
      color 180ms ease,
      box-shadow 180ms ease;
  }

  .navegacao__link:hover {
    background: var(--cor-nav-hover);
    color: var(--cor-nav-hover-texto);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.14);
  }

  .navegacao__link--ativo {
    background: var(--cor-nav-ativo);
    color: var(--cor-nav-ativo-texto);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.72),
      0 8px 20px rgba(0, 0, 0, 0.18);
  }

  @media (max-width: 520px) {
    .cabecalho-site {
      padding-inline: var(--espaco-3);
    }

    .navegacao {
      width: 100%;
      overflow-x: hidden;
      scrollbar-width: none;
    }

    .navegacao::-webkit-scrollbar {
      display: none;
    }

    .navegacao__lista {
      justify-content: space-between;
      min-width: 0;
    }

    .navegacao__link {
      gap: var(--espaco-1);
      padding-inline: var(--espaco-2);
      font-size: 0.76rem;
    }
  }

  @media (max-width: 420px) {
    .cabecalho-site {
      padding-inline: var(--espaco-2);
    }

    .navegacao__lista {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 2px;
      padding: 5px;
    }

    .navegacao__lista li {
      min-width: 0;
    }

    .navegacao__link {
      width: 100%;
      min-width: 0;
      padding-inline: 2px;
      font-size: 0.58rem;
    }

    .navegacao__link--ativo {
      padding-inline: 2px;
    }
  }
</style>

<script is:inline>
  const linksNavegacao = Array.from(document.querySelectorAll('[data-nav-link]'));
  const secoesNavegacao = linksNavegacao
    .map((link) => {
      const alvo = document.querySelector(link.getAttribute('href'));
      return alvo ? { link, alvo } : null;
    })
    .filter(Boolean);
  let navRaf = 0;

  const ativarLink = (id) => {
    linksNavegacao.forEach((link) => {
      const ativo = link.getAttribute('href') === `#${id}`;
      link.classList.toggle('navegacao__link--ativo', ativo);

      if (ativo) {
        link.setAttribute('aria-current', 'location');
      } else {
        link.removeAttribute('aria-current');
      }
    });
  };

  const atualizarNavegacao = () => {
    navRaf = 0;

    if (window.scrollY <= 24) {
      ativarLink('home');
      return;
    }

    const linhaAtiva = window.scrollY + window.innerHeight * 0.45;
    let idAtivo = 'home';

    secoesNavegacao.forEach(({ alvo }) => {
      if (alvo.offsetTop <= linhaAtiva) {
        idAtivo = alvo.id;
      }
    });

    ativarLink(idAtivo);
  };

  const agendarAtualizacao = () => {
    if (navRaf) return;
    navRaf = window.requestAnimationFrame(atualizarNavegacao);
  };

  linksNavegacao.forEach((link) => {
    link.addEventListener('click', () => {
      const id = link.getAttribute('href')?.replace('#', '');
      if (id) ativarLink(id);
    });
  });

  window.addEventListener('scroll', agendarAtualizacao, { passive: true });
  window.addEventListener('resize', agendarAtualizacao);
  window.addEventListener('hashchange', agendarAtualizacao);
  atualizarNavegacao();
</script>
