---
import { Image } from 'astro:assets';
import Icone from '../base/Icone.astro';

type MidiaModal =
  | {
      tipo: 'imagem';
      imagem: ImageMetadata;
      alt: string;
    }
  | {
      tipo: 'video';
      src: string;
      poster: ImageMetadata;
      alt: string;
    };

interface Props {
  id: string;
  titulo: string;
  resumo?: string;
  midia: MidiaModal;
  tema?: 'azul' | 'claro' | 'preto' | 'grafite';
  badges?: string[];
  links?: Array<{
    rotulo: string;
    url: string;
  }>;
  url?: string;
  rotuloLink?: string;
}

const {
  id,
  titulo,
  resumo,
  midia,
  tema = 'azul',
  badges = [],
  links = [],
  url,
  rotuloLink = 'View product'
} = Astro.props;

const tituloId = `${id}-titulo`;
const descricaoId = resumo ? `${id}-descricao` : undefined;
---

<dialog
  id={id}
  class={`modal-projeto modal-projeto--${tema}`}
  aria-labelledby={tituloId}
  aria-describedby={descricaoId}
  data-modal-projeto
>
  <div class="modal-projeto__painel" data-modal-painel data-lenis-prevent>
    <button
      class="modal-projeto__fechar"
      type="button"
      aria-label={`Close details for ${titulo}`}
      data-modal-fechar
    >
      <Icone nome="close" tamanho={20} />
    </button>

    <div class:list={['modal-projeto__midia', `modal-projeto__midia--${midia.tipo}`]}>
      {
        midia.tipo === 'imagem' ? (
          <Image
            src={midia.imagem}
            alt={midia.alt}
            widths={[720, 1080, 1440]}
            sizes="(min-width: 768px) 46vw, calc(100vw - 16px)"
            format="webp"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <video
            aria-label={midia.alt}
            poster={midia.poster.src}
            muted
            loop
            playsinline
            controls
            preload="metadata"
            data-modal-video
          >
            <source src={midia.src} type={midia.src.toLowerCase().endsWith('.webm') ? 'video/webm' : 'video/mp4'} />
            Your browser does not support HTML video.
          </video>
        )
      }
    </div>

    <div class="modal-projeto__conteudo" data-modal-conteudo data-lenis-prevent>
      <div class="modal-projeto__cabecalho">
        <h3 id={tituloId}>{titulo}</h3>
        {resumo && <p id={descricaoId}>{resumo}</p>}
      </div>

      {(badges.length > 0 || links.length > 0) && (
        <div class="modal-projeto__meta">
          {badges.length > 0 && (
            <ul class="modal-projeto__badges" aria-label="Project highlights">
              {badges.map((badge) => <li>{badge}</li>)}
            </ul>
          )}

          {links.length > 0 && (
            <div class="modal-projeto__grupo-links">
              <p class="modal-projeto__rotulo-links">Launch references</p>
              <ul class="modal-projeto__lista-links" aria-label="Launch references">
                {links.map((link) => (
                  <li>
                    <a class="modal-projeto__link-badge" href={link.url} target="_blank" rel="noreferrer" data-modal-link>
                      <span>{link.rotulo}</span>
                      <Icone nome="external-link" tamanho={15} />
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      )}

      <div class="modal-projeto__editorial">
        <slot />
      </div>

      {url && (
        <a class="modal-projeto__link" href={url} data-modal-link>
          {rotuloLink}
          <Icone nome="external-link" tamanho={17} />
        </a>
      )}
    </div>
  </div>
</dialog>

<style>
  .modal-projeto {
    --modal-fundo: #ffffff;
    --modal-texto: #111111;
    --modal-texto-suave: #50555c;
    --modal-borda: rgba(17, 17, 17, 0.12);
    --modal-superficie: #f5f6f7;
    width: calc(100vw - 32px);
    width: calc(100dvw - 32px);
    max-width: none;
    height: calc(100vh - 32px);
    height: calc(100dvh - 32px);
    max-height: none;
    margin: auto;
    overflow: hidden;
    border: 1px solid var(--modal-borda);
    border-radius: clamp(18px, 2vw, 28px);
    padding: 0;
    background: var(--modal-fundo);
    color: var(--modal-texto);
    box-shadow: 0 40px 120px rgba(0, 0, 0, 0.38);
    opacity: 0;
    transform: translateY(12px) scale(0.985);
    transition:
      opacity 220ms ease-out,
      transform 220ms ease-out,
      display 220ms allow-discrete,
      overlay 220ms allow-discrete;
  }

  .modal-projeto--claro {
    background: var(--modal-fundo);
  }

  .modal-projeto--preto {
    background: var(--modal-fundo);
  }

  .modal-projeto--grafite {
    background: var(--modal-fundo);
  }

  .modal-projeto--preto .modal-projeto__painel,
  .modal-projeto--preto .modal-projeto__conteudo,
  .modal-projeto--grafite .modal-projeto__painel,
  .modal-projeto--grafite .modal-projeto__conteudo {
    background: var(--modal-fundo);
    color: var(--modal-texto);
  }

  .modal-projeto--grafite .modal-projeto__painel,
  .modal-projeto--grafite .modal-projeto__conteudo {
    background: var(--modal-fundo);
  }

  .modal-projeto[open] {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .modal-projeto.modal-projeto--fechando {
    opacity: 0;
    transform: translateY(8px) scale(0.99);
  }

  .modal-projeto::backdrop {
    background: var(--cor-modal-scrim);
    backdrop-filter: blur(18px);
    opacity: 0;
    transition:
      opacity 220ms ease-out,
      display 220ms allow-discrete,
      overlay 220ms allow-discrete;
  }

  .modal-projeto[open]::backdrop {
    opacity: 1;
  }

  .modal-projeto.modal-projeto--fechando::backdrop {
    opacity: 0;
  }

  .modal-projeto__painel {
    position: relative;
    display: grid;
    width: 100%;
    height: 100%;
    min-width: 0;
    grid-template-columns: minmax(0, 46fr) minmax(0, 54fr);
    overflow: hidden;
  }

  .modal-projeto__fechar {
    position: absolute;
    top: max(var(--espaco-4), env(safe-area-inset-top));
    right: max(var(--espaco-4), env(safe-area-inset-right));
    z-index: 4;
    display: grid;
    width: 44px;
    height: 44px;
    place-items: center;
    border: 1px solid var(--modal-borda);
    border-radius: 50%;
    padding: 0;
    background: rgba(255, 255, 255, 0.92);
    color: var(--modal-texto);
    cursor: pointer;
    box-shadow: 0 10px 24px rgba(17, 17, 17, 0.08);
    touch-action: manipulation;
    transition:
      background-color 180ms ease,
      border-color 180ms ease,
      transform 180ms ease;
  }

  .modal-projeto__fechar:hover {
    background: #ffffff;
    border-color: rgba(17, 17, 17, 0.24);
  }

  .modal-projeto__fechar:active {
    transform: scale(0.94);
  }

  .modal-projeto__midia {
    display: block;
    position: relative;
    min-width: 0;
    min-height: 0;
    overflow: hidden;
    border-right: 1px solid var(--modal-borda);
    background: var(--modal-superficie);
  }

  .modal-projeto--claro .modal-projeto__midia {
    background: var(--modal-superficie);
  }

  .modal-projeto--preto .modal-projeto__midia {
    background: var(--modal-superficie);
  }

  .modal-projeto--grafite .modal-projeto__midia {
    background: var(--modal-superficie);
  }

  .modal-projeto__midia :global(picture),
  .modal-projeto__midia :global(img),
  .modal-projeto__midia video {
    display: block;
    width: 100%;
    height: 100%;
    max-width: 100%;
  }

  .modal-projeto__midia :global(picture) {
    min-height: 100%;
  }

  .modal-projeto__midia--imagem :global(img) {
    object-fit: cover;
    object-position: center center;
  }

  .modal-projeto__midia--video video {
    object-fit: contain;
  }

  .modal-projeto__conteudo {
    min-width: 0;
    min-height: 0;
    overflow-x: hidden;
    overflow-y: auto;
    overscroll-behavior: contain;
    touch-action: pan-y;
    padding:
      clamp(4rem, 8vh, 7rem)
      clamp(2rem, 6vw, 6.5rem)
      clamp(3rem, 7vh, 6rem);
    scrollbar-color: color-mix(in srgb, var(--modal-texto) 52%, transparent) transparent;
    scrollbar-width: thin;
  }

  .modal-projeto__conteudo::-webkit-scrollbar {
    width: 8px;
  }

  .modal-projeto__conteudo::-webkit-scrollbar-track {
    background: transparent;
  }

  .modal-projeto__conteudo::-webkit-scrollbar-thumb {
    border: 2px solid transparent;
    border-radius: var(--raio-pilula);
    background: color-mix(in srgb, var(--modal-texto) 52%, transparent);
    background-clip: padding-box;
  }

  .modal-projeto__cabecalho h3,
  .modal-projeto__cabecalho p {
    margin: 0;
  }

  .modal-projeto__cabecalho h3 {
    max-width: 12ch;
    padding-right: var(--espaco-10);
    font-family: var(--fonte-display);
    font-size: clamp(3rem, 6vw, 7rem);
    font-weight: 650;
    line-height: 0.92;
    letter-spacing: var(--tracking-titulo);
    overflow-wrap: anywhere;
    text-wrap: balance;
  }

  .modal-projeto__cabecalho p {
    max-width: 54ch;
    margin-top: var(--espaco-8);
    color: var(--modal-texto-suave);
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    line-height: 1.65;
  }

  .modal-projeto__editorial {
    max-width: 68ch;
    margin-top: var(--espaco-10);
    color: var(--modal-texto-suave);
  }

  .modal-projeto__meta {
    display: grid;
    gap: var(--espaco-6);
    max-width: 68ch;
    margin-top: var(--espaco-8);
  }

  .modal-projeto__badges,
  .modal-projeto__lista-links {
    display: grid;
    gap: var(--espaco-3);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .modal-projeto__badges {
    grid-template-columns: repeat(auto-fit, minmax(180px, max-content));
  }

  .modal-projeto__badges li {
    display: inline-flex;
    min-height: 36px;
    align-items: center;
    width: fit-content;
    max-width: 100%;
    border: 1px solid rgba(17, 17, 17, 0.12);
    border-radius: var(--raio-pilula);
    padding: 0.55rem 0.9rem;
    background: #f5f6f7;
    color: var(--modal-texto);
    font-size: 0.85rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .modal-projeto__grupo-links {
    display: grid;
    gap: var(--espaco-3);
  }

  .modal-projeto__rotulo-links {
    margin: 0;
    color: var(--modal-texto-suave);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .modal-projeto__lista-links li {
    width: min(100%, 30rem);
  }

  .modal-projeto__link-badge {
    display: grid;
    width: 100%;
    min-height: 52px;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--espaco-3);
    border: 1px solid rgba(17, 17, 17, 0.12);
    border-radius: 14px;
    padding: 0.85rem 1rem;
    background: #ffffff;
    box-shadow: 0 8px 20px rgba(17, 17, 17, 0.05);
    color: var(--modal-texto);
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.2;
    text-decoration: none;
    transition:
      background-color 180ms ease,
      border-color 180ms ease,
      transform 180ms ease;
  }

  .modal-projeto__link-badge span {
    min-width: 0;
  }

  .modal-projeto__link-badge:hover,
  .modal-projeto__link-badge:focus-visible {
    background: #f7f8f9;
    border-color: rgba(17, 17, 17, 0.24);
    transform: translateY(-1px);
  }

  .modal-projeto__link-badge:active {
    transform: translateY(0);
  }

  .modal-projeto__editorial :global(> :first-child) {
    margin-top: 0;
  }

  .modal-projeto__editorial :global(h2),
  .modal-projeto__editorial :global(h3),
  .modal-projeto__editorial :global(h4) {
    margin: var(--espaco-10) 0 0;
    color: var(--modal-texto);
    font-family: var(--fonte-display);
    line-height: 1.1;
    text-wrap: balance;
  }

  .modal-projeto__editorial :global(h2) {
    font-size: clamp(1.8rem, 3vw, 3rem);
  }

  .modal-projeto__editorial :global(h3) {
    font-size: clamp(1.4rem, 2.2vw, 2.2rem);
  }

  .modal-projeto__editorial :global(p),
  .modal-projeto__editorial :global(ul),
  .modal-projeto__editorial :global(ol) {
    margin: var(--espaco-5) 0 0;
    font-size: 1rem;
    line-height: 1.7;
  }

  .modal-projeto__editorial :global(ul),
  .modal-projeto__editorial :global(ol) {
    display: grid;
    gap: var(--espaco-3);
    padding-left: var(--espaco-6);
  }

  .modal-projeto__editorial :global(a) {
    color: #0f4c81;
    font-weight: 600;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }

  .modal-projeto__editorial :global(img) {
    width: 100%;
    height: auto;
    margin-top: var(--espaco-8);
    border: 1px solid var(--modal-borda);
    border-radius: var(--raio-medio);
  }

  .modal-projeto__link {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    gap: var(--espaco-2);
    margin-top: var(--espaco-10);
    border: 1px solid var(--modal-texto);
    border-radius: var(--raio-pilula);
    padding: 0 var(--espaco-5);
    background: var(--modal-texto);
    color: #ffffff;
    font-weight: 650;
    line-height: 1;
    text-decoration: none;
    touch-action: manipulation;
    transition:
      opacity 180ms ease,
      transform 180ms ease;
  }

  .modal-projeto--claro .modal-projeto__link {
    color: #ffffff;
  }

  .modal-projeto--preto .modal-projeto__link {
    color: #ffffff;
  }

  .modal-projeto__link:hover {
    opacity: 0.84;
  }

  .modal-projeto__link:active {
    transform: scale(0.98);
  }

  @media (max-width: 767px) {
    .modal-projeto {
      width: calc(100vw - 16px);
      width: calc(100dvw - 16px);
      height: calc(100vh - 16px);
      height: calc(100dvh - 16px);
      border-radius: 20px;
    }

    .modal-projeto__painel {
      display: block;
      overflow-x: hidden;
      overflow-y: auto;
      overscroll-behavior: contain;
      touch-action: pan-y;
    }

    .modal-projeto__midia {
      width: 100%;
      height: auto;
      min-height: 0;
      aspect-ratio: 16 / 11;
      border-right: 0;
      border-bottom: 1px solid var(--modal-borda);
    }

    .modal-projeto__conteudo {
      overflow: visible;
      padding: var(--espaco-10) var(--espaco-5) var(--espaco-12);
    }

    .modal-projeto__cabecalho h3 {
      max-width: 11ch;
      padding-right: var(--espaco-8);
      font-size: clamp(2.5rem, 13vw, 4.4rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .modal-projeto,
    .modal-projeto::backdrop,
    .modal-projeto__fechar,
    .modal-projeto__link,
    .modal-projeto__link-badge {
      transition: none;
    }
  }

  @starting-style {
    .modal-projeto[open] {
      opacity: 0;
      transform: translateY(12px) scale(0.985);
    }

    .modal-projeto[open]::backdrop {
      opacity: 0;
    }
  }

  :global(html.modal-projeto-ativa),
  :global(html.modal-projeto-ativa body) {
    overflow: hidden;
  }
</style>
